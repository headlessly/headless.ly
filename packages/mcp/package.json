{
  "name": "@headlessly/mcp",
  "version": "0.1.0",
  "description": "MCP protocol client for headless.ly — search, fetch, do",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./stdio": {
      "types": "./src/stdio.ts",
      "import": "./dist/stdio.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./stdio": {
        "types": "./dist/stdio.d.ts",
        "import": "./dist/stdio.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:e2e": "vitest run --config ../vitest.e2e.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dotdo/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "digital-objects": "workspace:*",
    "mcp.do": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^3.0.2"
  },
  "keywords": [
    "headlessly",
    "mcp",
    "model-context-protocol",
    "digital-objects",
    "agent-first"
  ],
  "author": "headless.ly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/headlessly/headless.ly",
    "directory": "public/packages/mcp"
  },
  "homepage": "https://headless.ly"
}
